PORT=5000
CORS_ORIGIN=http://localhost:5173
SARVAM_API_KEY=your_sarvam_api_key
SARVAM_MODEL=sarvam-m

# Render-friendly Firebase Admin options. Use either FIREBASE_SERVICE_ACCOUNT as a single JSON string,
# or the three separate values below.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"astra-learn-706cb"}
FIREBASE_PROJECT_ID=astra-learn-706cb
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@example.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"
